# Never commit .env to version control.
# All secrets should be generated fresh per environment.
# Traefik

# Email used for ACME registration with Let's Encrypt.
TRAEFIK_ACME_EMAIL=your-email@example.com

# Name of the Traefik certificates resolver referenced by router labels.
TRAEFIK_CERT_RESOLVER=myresolver


# n8n

# Public hostname for the n8n editor and webhook URLs.
N8N_HOST=automation.example.com

# Container timezone in IANA format.
GENERIC_TIMEZONE=UTC

# Secret used by n8n to encrypt stored credentials.
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace_with_random_hex_key


# PostgreSQL

# Database name used by n8n.
POSTGRES_DB=n8n

# Application database user.
POSTGRES_USER=n8n

# Strong password for the application database user.
POSTGRES_PASSWORD=replace_with_strong_password


# Offers app

# Public hostname exposed through Traefik.
OFFERS_HOST=offers.example.com

# Username expected by the offers form service.
OFFERS_FORM_USERNAME=replace_with_username

# Password expected by the offers form service.
OFFERS_FORM_PASSWORD=replace_with_password

# Application token used by the offers service.
# Generate with: openssl rand -hex 32
OFFERS_RENDER_TOKEN=replace_with_random_token

# Full webhook URL consumed by the offers app and handled by n8n.
N8N_OFFERS_WEBHOOK_URL=https://automation.example.com/webhook/offers-submit
